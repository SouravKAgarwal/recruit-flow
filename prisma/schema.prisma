// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  avatar       String?
  createdAt    DateTime @default(now())

  smtpAccounts   SmtpAccount[]
  resumes        Resume[]
  recruiters     Recruiter[]
  templates      EmailTemplate[]
  campaigns      Campaign[]
  emailLogs      EmailLog[]
}

// ─── SMTP Accounts ───────────────────────────────────────────────────────────

model SmtpAccount {
  id                String    @id @default(uuid())
  userId            String
  label             String    // e.g. "Gmail - Work"
  senderName        String
  email             String
  host              String
  port              Int       @default(587)
  username          String
  encryptedPassword String
  tls               Boolean   @default(true)
  isDefault         Boolean   @default(false)
  emailsSent        Int       @default(0)
  lastUsedAt        DateTime?
  createdAt         DateTime  @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns Campaign[]
  emailLogs EmailLog[]
}

// ─── Resumes ─────────────────────────────────────────────────────────────────

model Resume {
  id           String   @id @default(uuid())
  userId       String
  filename     String   // stored on disk
  originalName String   // display name
  size         Int      @default(0)
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailLogs EmailLog[]
}

// ─── Recruiters ──────────────────────────────────────────────────────────────

model Recruiter {
  id              String    @id @default(uuid())
  userId          String
  name            String    @default("")
  company         String    @default("")
  role            String    @default("")
  email           String    @default("")
  linkedin        String    @default("")
  location        String    @default("")
  status          String    @default("NEW")       // NEW, CONTACTED, REPLIED, INTERVIEW, OFFER, REJECTED
  crmStage        String    @default("new")       // kanban column
  tags            String    @default("")          // comma-separated
  notes           String    @default("")
  lastContactedAt DateTime?
  createdAt       DateTime  @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailLogs EmailLog[]
}

// ─── Email Templates ─────────────────────────────────────────────────────────

model EmailTemplate {
  id        String   @id @default(uuid())
  userId    String
  name      String
  subject   String   @default("")
  body      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns Campaign[]
  emailLogs EmailLog[]
}

// ─── Campaigns ───────────────────────────────────────────────────────────────

model Campaign {
  id            String    @id @default(uuid())
  userId        String
  name          String    @default("Campaign")
  smtpAccountId String?
  templateId    String?
  status        String    @default("DRAFT")  // DRAFT, RUNNING, PAUSED, COMPLETED, FAILED
  totalEmails   Int       @default(0)
  sentEmails    Int       @default(0)
  failedEmails  Int       @default(0)
  delayMs       Int       @default(1500)
  scheduledAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  smtpAccount SmtpAccount?  @relation(fields: [smtpAccountId], references: [id])
  template    EmailTemplate? @relation(fields: [templateId], references: [id])
  emailLogs   EmailLog[]
}

// ─── Email Logs ──────────────────────────────────────────────────────────────

model EmailLog {
  id            String    @id @default(uuid())
  userId        String
  recruiterId   String?
  campaignId    String?
  smtpAccountId String?
  templateId    String?
  resumeId      String?
  toEmail       String
  subject       String    @default("")
  status        String    @default("SENT")   // QUEUED, SENT, OPENED, CLICKED, REPLIED, FAILED
  errorMessage  String?
  sentAt        DateTime  @default(now())
  openedAt      DateTime?
  repliedAt     DateTime?

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  recruiter   Recruiter?     @relation(fields: [recruiterId], references: [id])
  campaign    Campaign?      @relation(fields: [campaignId], references: [id])
  smtpAccount SmtpAccount?   @relation(fields: [smtpAccountId], references: [id])
  template    EmailTemplate? @relation(fields: [templateId], references: [id])
  resume      Resume?        @relation(fields: [resumeId], references: [id])
}

// ─── Legacy job runner (kept for backwards compat) ───────────────────────────

model Job {
  id                 String   @id @default(uuid())
  status             String   // PENDING, SENDING, COMPLETED, FAILED, CANCELLED
  total              Int      @default(0)
  sent               Int      @default(0)
  failed             Int      @default(0)
  skipped            Int      @default(0)
  currentEmail       String   @default("")
  recipientsFilename String
  resumeFilename     String   @default("")
  templateText       String
  createdAt          DateTime @default(now())
  logs               Log[]
}

model Log {
  id        String   @id @default(uuid())
  jobId     String
  timestamp DateTime @default(now())
  level     String   // INFO, WARNING, ERROR, SUCCESS
  message   String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}
